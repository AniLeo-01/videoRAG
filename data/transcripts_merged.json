  "VQRLujxTm3c": [
    {
      "text": "What you doing up there?",
      "start": 10.0,
      "duration": 1.0
    },
    {
      "text": "Oh, just fixing some leaks.",
      "start": 11.0,
      "duration": 2.0
    },
    {
      "text": "Seriously dude, you got some time on your hands.",
      "start": 13.0,
      "duration": 2.0
    },
    {
      "text": "I got some properties with paying tenants.",
      "start": 15.0,
      "duration": 4.0
    },
    {
      "text": "What, that's why you came by?",
      "start": 19.0,
      "duration": 1.0
    },
    {
      "text": "Just go get me my checks!",
      "start": 20.0,
      "duration": 3.0
    },
    {
      "text": "See you, Brian.",
      "start": 23.0,
      "duration": 1.0
    },
    {
      "text": "Love you, Jason.",
      "start": 24.0,
      "duration": 4.0
    },
    {
      "text": "Hi Jason!",
      "start": 28.0,
      "duration": 22.0
    },
    {
      "text": "I'm here for Lucia Caminos.",
      "start": 50.0,
      "duration": 2.0
    },
    {
      "text": "She's supposed to be getting out.",
      "start": 52.0,
      "duration": 2.0
    },
    {
      "text": "What's your name?",
      "start": 54.0,
      "duration": 1.0
    },
    {
      "text": "Jason Duval.",
      "start": 55.0,
      "duration": 2.0
    },
    {
      "text": "I seen you here before?",
      "start": 57.0,
      "duration": 2.0
    },
    {
      "text": "You might have.",
      "start": 59.0,
      "duration": 8.0
    },
    {
      "text": "Hey.",
      "start": 67.0,
      "duration": 1.0
    },
    {
      "text": "Hey.",
      "start": 68.0,
      "duration": 7.0
    },
    {
      "text": "Hands above your head!",
      "start": 75.0,
      "duration": 1.0
    },
    {
      "text": "Now! You, stay!",
      "start": 76.0,
      "duration": 3.0
    },
    {
      "text": "To new beginnings.",
      "start": 79.0,
      "duration": 2.0
    },
    {
      "text": "You broke my nose, that's what.",
      "start": 81.0,
      "duration": 6.0
    },
    {
      "text": "Trust me, this place is just a start for us.",
      "start": 87.0,
      "duration": 2.0
    },
    {
      "text": "Ring the bell!",
      "start": 89.0,
      "duration": 1.0
    },
    {
      "text": "Shots baby!",
      "start": 90.0,
      "duration": 2.0
    },
    {
      "text": "The only thing that matters is who you know",
      "start": 92.0,
      "duration": 2.0
    },
    {
      "text": "and what you got.",
      "start": 94.0,
      "duration": 3.0
    },
    {
      "text": "If we're gonna do this,",
      "start": 97.0,
      "duration": 1.0
    },
    {
      "text": "we're doing it right.",
      "start": 98.0,
      "duration": 4.0
    },
    {
      "text": "Yo D, this fool a Fed?",
      "start": 102.0,
      "duration": 2.0
    },
    {
      "text": "They got your name, address.",
      "start": 104.0,
      "duration": 2.0
    },
    {
      "text": "They got everything.",
      "start": 106.0,
      "duration": 2.0
    },
    {
      "text": "Us cops, we gotta protect each other.",
      "start": 108.0,
      "duration": 3.0
    },
    {
      "text": "Like, brap brap brap!",
      "start": 111.0,
      "duration": 4.0
    },
    {
      "text": "You and me Lu, we got this.",
      "start": 115.0,
      "duration": 2.0
    },
    {
      "text": "We got it.",
      "start": 117.0,
      "duration": 1.0
    },
    {
      "text": "Whoa!",
      "start": 118.0,
      "duration": 6.0
    },
    {
      "text": "Say Vice City, baby.",
      "start": 124.0,
      "duration": 2.0
    },
    {
      "text": "Vice City, baby!",
      "start": 126.0,
      "duration": 3.0
    },
    {
      "text": "Come to Phil's Ammu-Nation today!",
      "start": 129.0,
      "duration": 3.0
    },
    {
      "text": "We got more guns than the law allows.",
      "start": 132.0,
      "duration": 2.0
    },
    {
      "text": "Woohoo!",
      "start": 134.0,
      "duration": 2.0
    },
    {
      "text": "Hey.",
      "start": 136.0,
      "duration": 14.0
    },
    {
      "text": "Hey if you got friends,",
      "start": 150.0,
      "duration": 1.0
    },
    {
      "text": "can you hook me up please!",
      "start": 151.0,
      "duration": 2.0
    },
    {
      "text": "Hahaha!",
      "start": 153.0,
      "duration": 3.0
    }
